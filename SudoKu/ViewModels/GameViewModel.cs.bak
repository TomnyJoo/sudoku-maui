    /// <summary>鑾峰彇鏁板瓧浣跨敤娆℃暟缁熻銆?/summary>
    /// <remarks>
    /// 瀵逛簬姝﹀＋鏁扮嫭锛屽彧璁＄畻褰撳墠瀛愮綉鏍肩殑鏁板瓧璁℃暟锛堜笌Flutter瀹炵幇涓€鑷达級銆?    /// </remarks>
    public Dictionary<int, int> NumberCounts
    {
        get
        {
            if (CurrentState?.Board is null) return [];

            // 浣跨敤 GameType 鍒ゆ柇鏄惁鏄澹暟鐙?            if (CurrentState.GameType == GameType.Samurai && CurrentState.Board is Board board)
            {
                return CalculateSamuraiSubGridNumberCounts(board, CurrentSubGridIndex);
            }

            return CurrentState.NumberCounts;
        }
    }

    /// <summary>璁＄畻姝﹀＋鏁扮嫭瀛愮綉鏍肩殑鏁板瓧璁℃暟銆?/summary>
    private static Dictionary<int, int> CalculateSamuraiSubGridNumberCounts(Board board, int subGridIndex)
    {
        var counts = new Dictionary<int, int>();
        for (int i = 1; i <= 9; i++)
        {
            counts[i] = 0;
        }

        // 杈圭晫妫€鏌?        if (subGridIndex < 0 || subGridIndex >= SamuraiConstants.SubGridCount)
        {
            return counts;
        }

        var (startRow, startCol) = SamuraiConstants.SubGridOffsets[subGridIndex];
        for (int r = 0; r < SamuraiConstants.SubGridSize; r++)
        {
            for (int c = 0; c < SamuraiConstants.SubGridSize; c++)
            {
                var cell = board.Cells[startRow + r][startCol + c];
                if (cell.Value != null)
                {
                    counts[cell.Value.Value]++;
                }
            }
        }

        return counts;
    }

    /// <summary>鑾峰彇姣忎釜鏁板瓧鐨勬渶澶т娇鐢ㄦ鏁帮紙姝﹀＋鏁扮嫭涓?锛屽叾浠栦负9锛夈€?/summary>
    /// <remarks>
    /// 娉ㄦ剰锛氭澹暟鐙櫧鐒舵暣涓鐩樻湁21x21锛屼絾鏁板瓧閿洏鍙绠楀綋鍓嶅瓙缃戞牸鐨勬暟瀛楄鏁帮紝
    /// 鎵€浠ユ渶澶т娇鐢ㄦ鏁颁粛鐒舵槸9锛堟瘡涓暟瀛楀湪9x9瀛愮綉鏍间腑鏈€澶氬嚭鐜?娆★級銆?    /// </remarks>
    public static int MaxNumberCount => 9;

