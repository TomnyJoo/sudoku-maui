    #region 娓告垙鐢熷懡鍛ㄦ湡鏂规硶

    /// <summary>
    /// 寮傛鍒濆鍖栨父鎴忥紝鏍规嵁鍙傛暟鍐冲畾鍒涘缓鏂版父鎴忔垨鍔犺浇宸蹭繚瀛樼殑娓告垙銆?    /// </summary>
    /// <param name="parameter">瀵艰埅鍙傛暟锛屽寘鍚?GameType銆丏ifficulty銆両sNewGame銆?/param>
    /// <returns>鍒濆鍖栧畬鎴愮殑浠诲姟銆?/returns>
    public override async Task InitializeAsync(object? parameter = null)
    {
        if (parameter is not Dictionary<string, object> paramsDict)
            return;

        var gameType = paramsDict.TryGetValue("GameType", out var gt) ? (GameType)gt : GameType.Standard;
        var difficulty = paramsDict.TryGetValue("Difficulty", out var diff) ? (Difficulty)diff : Difficulty.Medium;
        var isNewGame = paramsDict.TryGetValue("IsNewGame", out var isNew) && (bool)isNew;

        // 鏀寔鑷畾涔夋鐩?        if (paramsDict.TryGetValue("CustomBoardJson", out var boardJsonObj) && boardJsonObj is string boardJsonStr)
        {
            var customBoard = DeserializeCustomBoard(boardJsonStr, gameType);
            if (customBoard != null)
            {
                CurrentState = new GameState<Board>
                {
                    Board = customBoard,
                    InitialBoard = customBoard.DeepCopy(),
                    Solution = customBoard,
                    GameType = gameType,
                    Difficulty = difficulty,
                    Status = GameStatus.Playing,
                    StartTime = DateTime.Now,
                    History = [customBoard],
                    HistoryIndex = 0
                };
                Title = GetLocalizedGameTypeName(gameType);
                UpdateDerivedProperties();
                StartTimer();
                return;
            }
        }

        if (isNewGame)
        {
            await StartNewGameAsync(gameType, difficulty);
        }
        else
        {
            await LoadSavedGameAsync(gameType, difficulty);
        }

        // 骞惰鍔犺浇鏈€浣虫垚缁?        _ = LoadBestScoreAsync(gameType, difficulty);
    }

    #region 瀵艰埅鐘舵€佺鐞?
    /// <summary>
    /// 澶勭悊椤甸潰瀵艰埅鍒颁簨浠?    /// </summary>
    public async Task HandleNavigatedToAsync(IDictionary<string, object>? parameters)
    {
        System.Diagnostics.Debug.WriteLine($"[GameViewModel] HandleNavigatedToAsync: parameters={(parameters != null ? parameters.Count : -1)}, CurrentState={(CurrentState != null ? "exists" : "null")}, _lastGameType={_lastGameType}, _lastDifficulty={_lastDifficulty}");

        if (parameters != null && parameters.Count > 0)
        {
            await InitializeAsync(parameters);
            _isFirstNavigation = false;
            _hasActiveGame = true;

            if (parameters.TryGetValue("GameType", out var gt) && gt is GameType gameType)
            {
                _lastGameType = gameType;
            }
            if (parameters.TryGetValue("Difficulty", out var diff) && diff is Difficulty difficulty)
            {
                _lastDifficulty = difficulty;
            }
        }
        else if (CurrentState != null)
        {
            _hasActiveGame = true;
        }
        else if (_lastGameType.HasValue && _lastDifficulty.HasValue)
        {
            System.Diagnostics.Debug.WriteLine($"[GameViewModel] HandleNavigatedToAsync: Restoring with lastGameType={_lastGameType}, lastDifficulty={_lastDifficulty}");
            await InitializeAsync(new Dictionary<string, object>
            {
                { "GameType", _lastGameType.Value },
                { "Difficulty", _lastDifficulty.Value },
                { "IsNewGame", false }
            });
        }
    }

    /// <summary>
    /// 澶勭悊椤甸潰绂诲紑浜嬩欢
    /// </summary>
    public void HandleNavigatedFrom()
    {
        SaveGameDebounced();
    }

    /// <summary>
    /// 妫€鏌ユ槸鍚﹂渶瑕侀噸鏂板垵濮嬪寲瑙嗗浘
    /// </summary>
    public bool ShouldReinitializeView()
    {
        return _isFirstNavigation || !_hasActiveGame;
    }

    #endregion

    /// <summary>
    /// 寮傛娓呯悊 ViewModel 璧勬簮銆?    /// </summary>
    public override Task CleanupAsync()
    {
        StopTimer();
        CancelAutoMarkDebounce();
        CancelSaveDebounce();
        _generationCts?.Cancel();
        _generationCts?.Dispose();
        return base.CleanupAsync();
    }

    /// <summary>
    /// 寮傛寮€濮嬫柊娓告垙銆?    /// </summary>
    /// <param name="gameType">娓告垙绫诲瀷銆?/param>
    /// <param name="difficulty">闅惧害绛夌骇銆?/param>
    private async Task StartNewGameAsync(GameType gameType, Difficulty difficulty)
    {
        IsGenerating = true;
        Title = GetLocalizedGameTypeName(gameType);

        // Allow UI to update (show generation overlay and hide board/keyboard)
        // before heavy generation work starts. This yields to the message loop so
        // the view can reflect IsGenerating immediately.
        await Task.Yield();

        // 閲嶇疆姝﹀＋鏁扮嫭鐘舵€?        if (gameType == GameType.Samurai)
        {
            _currentSubGridIndex = 4; // 榛樿鏄剧ず涓績缃戞牸
            _isOverviewMode = false;
            OnPropertyChanged(nameof(CurrentSubGridIndex));
            OnPropertyChanged(nameof(IsOverviewMode));
        }

        _generationCts = new CancellationTokenSource();

        var progress = new Progress<GenerationStage>(stage =>
        {
            MainThread.BeginInvokeOnMainThread(() =>
            {
                CurrentGenerationStage = stage;
            });
        });

        try
        {
            // 灏嗚€楁椂鐨勭敓鎴愬伐浣滄斁鍒板悗鍙扮嚎绋嬫墽琛岋紝鍏佽 UI 绾跨▼淇濇寔鍝嶅簲骞舵樉绀虹敓鎴愰伄缃┿€?            var state = await Task.Run(async () => await _gameService.CreateNewGameAsync(gameType, difficulty, _generationCts.Token, progress));

            // 鍦ㄤ富绾跨▼鏇存柊鐘舵€佷笌 UI
            MainThread.BeginInvokeOnMainThread(() =>
            {
                CurrentState = state;
                IsGenerating = false;
                UpdateDerivedProperties();
                StartTimer();
            });

            // 鎾斁寮€濮嬮煶鏁堬紙涓嶄緷璧?UI 鎿嶄綔锛?            await _audioService.PlayStartSoundAsync();
        }
        catch (OperationCanceledException)
        {
            // 鍙栨秷鏃剁‘淇濆湪涓荤嚎绋嬫洿鏂扮姸鎬?            MainThread.BeginInvokeOnMainThread(() => IsGenerating = false);
            await Shell.Current.DisplayAlertAsync(
                AppResources.Cancel,
                AppResources.Gen_UserCancelled,
                AppResources.Button_OK);
            await NavigationService.GoToRootAsync();
        }
        catch (Exception ex)
        {
            MainThread.BeginInvokeOnMainThread(() => IsGenerating = false);
            await Shell.Current.DisplayAlertAsync(
                AppResources.Error,
                ex.Message,
                AppResources.Button_OK);
            await NavigationService.GoToRootAsync();
        }
    }

    /// <summary>
    /// 寮傛鍔犺浇宸蹭繚瀛樼殑娓告垙銆?    /// </summary>
    /// <param name="gameType">娓告垙绫诲瀷銆?/param>
    /// <param name="difficulty">闅惧害绛夌骇銆?/param>
    private async Task LoadSavedGameAsync(GameType gameType, Difficulty difficulty)
    {
        var savedState = await _storageService.LoadGameAsync(gameType, difficulty);
        if (savedState is not null)
        {
            CurrentState = savedState;
            Title = GetLocalizedGameTypeName(gameType);
            ElapsedTimeDisplay = FormatTime(savedState.ElapsedTime);
            UpdateDerivedProperties();

            if (!savedState.IsCompleted)
            {
                StartTimer();
            }
        }
        else
        {
            await StartNewGameAsync(gameType, difficulty);
        }
    }

    /// <summary>
    /// 鍙栨秷娓告垙鐢熸垚銆?    /// </summary>
    [RelayCommand]
    private void CancelGeneration()
    {
        _generationCts?.Cancel();
        IsGenerating = false;
    }

    /// <summary>
    /// 寮€濮嬫柊娓告垙鍛戒护锛岄噸鏂扮敓鎴愬綋鍓嶇被鍨嬪拰闅惧害鐨勬柊娓告垙銆?    /// </summary>
    [RelayCommand]
    private async Task NewGame()
    {
        if (CurrentState is null) return;
        StopTimer();
        await StartNewGameAsync(CurrentState.GameType, CurrentState.Difficulty);
    }

