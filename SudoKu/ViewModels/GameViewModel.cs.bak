    [RelayCommand]
    private void ToggleCages() => ShowCages = !ShowCages;

    /// <summary>鍒囨崲姝﹀＋鏁扮嫭鎬昏妯″紡鍛戒护銆?/summary>
    [RelayCommand]
    private void ToggleOverview() => IsOverviewMode = !IsOverviewMode;

    /// <summary>鍒囨崲鍒颁笂涓€涓澹暟鐙瓙缃戞牸銆?/summary>
