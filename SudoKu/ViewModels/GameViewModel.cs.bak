    [RelayCommand]
    private void Resume() => StartTimer();

    /// <summary>
    /// 閲嶇疆娓告垙鍛戒护锛屾仮澶嶅埌鍒濆璋滈鐘舵€併€?    /// </summary>
    [RelayCommand]
