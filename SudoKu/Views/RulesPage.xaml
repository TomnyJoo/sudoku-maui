<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SudoKu.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="SudoKu.Views.RulesPage"
             x:DataType="vm:RulesViewModel"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">
        <!-- 标题栏 -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *" Padding="16,12" BackgroundColor="Transparent">
            <ImageButton Grid.Column="0" Source="arrow_back.png"
                         Style="{StaticResource ImageIconButtonStyle}"
                         Command="{Binding BackCommand}">
                <ImageButton.Behaviors>
                    <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource PrimaryTextColor}, Dark=White}" />
                </ImageButton.Behaviors>
            </ImageButton>
            <Label Grid.Column="1" Text="{Binding Title}" FontSize="20" FontAttributes="Bold"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource PrimaryTextColor}, Dark=White}" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="12">

            <CollectionView ItemsSource="{Binding GameRules}" Margin="0,8,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:GameRuleDisplay">
                        <Border Background="{StaticResource CardBackgroundColor}"
                               Padding="16" Margin="0,0,0,12" StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="8">

                                <!-- Rule Title -->
                                <Label Text="{Binding Title}" FontSize="20" FontAttributes="Bold" />

                                <!-- Description -->
                                <Label Text="{Binding Description}" FontSize="14"
                                       TextColor="{StaticResource SecondaryTextColor}"
                                       LineBreakMode="WordWrap" />

                                <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" Margin="0,4" />

                                <!-- Rules List -->
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Rules}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Padding="0,4" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                <Label Grid.Column="0" Text="&#x2022;" FontSize="14"
                                                       VerticalOptions="Start" />
                                                <Label Grid.Column="1" Text="{Binding .}" FontSize="14"
                                                       LineBreakMode="WordWrap" />
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
    </Grid>

</ContentPage>
